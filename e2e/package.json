{
  "name": "cats-lote-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end browser tests for cats-lote presentations",
  "scripts": {
    "build": "cd .. && sbt browserExamples/fastLinkJS",
    "serve": "npx http-server ../browser-examples -p 8080 --silent",
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed",
    "update-snapshots": "npx playwright test --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0"
  }
}

